{
  "name": "responses-starter-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "local-agent": "tsx local-agent/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:api": "playwright test tests/api",
    "test:e2e:ci": "playwright test --reporter=json --reporter=html --outputFile=test-results.json",
    "test:all": "npm run test && npm run test:e2e",
    "pretest:e2e": "npm run build",
    "posttest:e2e": "npm run test:e2e:report",
    "test:performance": "playwright test tests/performance/",
    "test:performance:load": "artillery run artillery-config.yml",
    "test:performance:lighthouse": "lhci autorun",
    "test:performance:memory": "playwright test tests/performance/memory-leaks.spec.ts",
    "test:performance:bundle": "playwright test tests/performance/bundle-size.spec.ts",
    "test:performance:network": "playwright test tests/performance/network-performance.spec.ts",
    "test:performance:all": "npm run test:performance && npm run test:performance:load && npm run test:performance:lighthouse",
    "perf:profile": "npm run build && npm run start",
    "perf:analyze": "npm run build && npx webpack-bundle-analyzer .next/static/chunks/*.js",
    "test:security": "playwright test tests/security/",
    "test:integration": "playwright test tests/integration/",
    "test:chaos": "playwright test tests/chaos/",
    "test:visual": "playwright test tests/visual/",
    "test:validation": "playwright test tests/validation/",
    "test:sentry": "playwright test tests/sentry/",
    "test:robustness": "npm run test:security && npm run test:integration && npm run test:chaos && npm run test:validation && npm run test:sentry",
    "test:complete": "npm run test:all && npm run test:performance:all && npm run test:robustness"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@composio/core": "^0.6.3",
    "@google/genai": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@monaco-editor/react": "^4.7.0",
    "@npmcli/fs": "^4.0.0",
    "@openai/agents": "^0.3.9",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@reach/visually-hidden": "^0.18.0",
    "@sentry/nextjs": "^8.55.0",
    "@sentry/replay": "^7.116.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tailwindcss/typography": "^0.5.19",
    "@xyflow/react": "^12.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "docx": "^9.5.1",
    "docx-preview": "^0.3.7",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.22",
    "lucide-react": "^0.441.0",
    "mongodb": "^7.0.0",
    "next": "^15.5.9",
    "next-auth": "^4.24.13",
    "node-pty": "^1.1.0",
    "openai": "^4.87.3",
    "openid-client": "^6.6.4",
    "partial-json": "^0.1.7",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^14.3.8",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.30.0",
    "react-syntax-highlighter": "^15.6.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.0.0",
    "ws": "^8.18.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@lhci/cli": "^0.12.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18",
    "@types/react-syntax-highlighter": "^15.5.13",
    "artillery": "^2.0.0",
    "bundlesize": "^0.18.1",
    "eslint": "^9.13.0",
    "eslint-config-next": "^15.5.9",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "node-mocks-http": "^1.17.2",
    "playwright-lighthouse": "^2.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  }
}
