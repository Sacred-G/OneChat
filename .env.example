OPENAI_API_KEY=<your-openai-api-key>
GOOGLE_API_KEY=<your-google-api-key>
APIPIE_API_KEY=<your-apipie-api-key>
MONGODB_URI=mongodb://127.0.0.1:27017/responses_starter_app
MONGODB_DB=responses_starter_app
GOOGLE_CLIENT_ID=<oauth-client-app-id>
GOOGLE_CLIENT_SECRET=<oauth-client-secret>
OAUTH_REDIRECT_URI="http://localhost:3000/api/google/callback"

# NextAuth
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=<your-github-oauth-client-id>
GITHUB_CLIENT_SECRET=<your-github-oauth-client-secret>

# Email Magic Link (optional - requires SMTP server)
EMAIL_SERVER_HOST=<smtp-host>
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=<smtp-user>
EMAIL_SERVER_PASSWORD=<smtp-password>
EMAIL_FROM=noreply@yourdomain.com

SENDGRID_API_KEY=<your-sendgrid-api-key>
SENDGRID_FROM_EMAIL=<verified-sender-email>
SENDGRID_FROM_NAME=<optional-sender-name>
SENDGRID_ALLOWED_RECIPIENTS=<comma-separated-allowlist-emails>

# Microsoft Graph API
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=your_microsoft_tenant_id
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/microsoft/callback

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_DSN=your_sentry_dsn_here
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
NEXT_PUBLIC_APP_VERSION=1.0.0

# Local Agent (optional - for development)
LOCAL_AGENT_URL=http://127.0.0.1:4001
LOCAL_AGENT_TOKEN=<your-local-agent-token>

DISABLE_MCP_TOOLS=false

# Debug flags
DEBUG_TURN_RESPONSE=false

# Composio Integration
COMPOSIO_API_KEY=your_composio_api_key

# Composio OAuth Apps
GITHUB_CLIENT_ID=your_github_oauth_client_id
SLACK_CLIENT_ID=your_slack_client_id
NOTION_CLIENT_ID=your_notion_client_id

# Composio API Keys (optional - can also be set via UI)
TAVILY_API_KEY=your_tavily_api_key
NOTION_API_KEY=your_notion_api_key
