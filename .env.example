OPENAI_API_KEY=<your-openai-api-key>
GOOGLE_API_KEY=<your-google-api-key>
APIPIE_API_KEY=<your-apipie-api-key>
MONGODB_URI=mongodb://127.0.0.1:27017/responses_starter_app
MONGODB_DB=responses_starter_app
GOOGLE_CLIENT_ID=<oauth-client-app-id>
GOOGLE_CLIENT_SECRET=<oauth-client-secret>
OAUTH_REDIRECT_URI="http://localhost:3000/api/google/callback"

# NextAuth
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=<your-github-oauth-client-id>
GITHUB_CLIENT_SECRET=<your-github-oauth-client-secret>

# Email Magic Link (optional - requires SMTP server)
EMAIL_SERVER_HOST=<smtp-host>
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=<smtp-user>
EMAIL_SERVER_PASSWORD=<smtp-password>
EMAIL_FROM=noreply@yourdomain.com

SENDGRID_API_KEY=<your-sendgrid-api-key>
SENDGRID_FROM_EMAIL=<verified-sender-email>
SENDGRID_FROM_NAME=<optional-sender-name>
SENDGRID_ALLOWED_RECIPIENTS=<comma-separated-allowlist-emails>

MICROSOFT_CLIENT_ID=<your-microsoft-app-client-id>
MICROSOFT_CLIENT_SECRET=<your-microsoft-app-client-secret>
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/microsoft/callback

DISABLE_MCP_TOOLS=false
